---
import type { CollectionEntry } from 'astro:content'
import BaseHead from '../components/base/BaseHead.astro'
import BlogTopNav from '../components/blog/BlogTopNav.astro'
import MarkdownCodeEnhancer from '../components/blog/MarkdownCodeEnhancer.vue'
import ReadingToc from '../components/blog/ReadingToc.vue'
import ArticleHero from '../components/blog/ArticleHero.astro'
import ArticleMeta from '../components/blog/ArticleMeta.astro'
import ArticleFooter from '../components/blog/ArticleFooter.astro'

interface HeadingItem {
  depth: number
  slug: string
  text: string
}

interface PostPreview {
  id: string
  title: string
  description: string
  pubDate: Date
}

type Props = CollectionEntry<'blog'>['data'] & {
  headings?: HeadingItem[]
  category?: string
  tags?: string[]
  readingMinutes?: number
  wordCount?: number
  prevPost?: PostPreview | null
  nextPost?: PostPreview | null
  relatedPosts?: PostPreview[]
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  headings = [],
  category = '技术随笔',
  tags = [],
  readingMinutes = 1,
  wordCount = 0,
  prevPost = null,
  nextPost = null,
  relatedPosts = [],
} = Astro.props

const tocHeadingCount = headings.filter((heading) => heading.depth <= 3).length
---

<html lang="zh-CN">
  <head>
    <BaseHead title={title} description={description} />
  </head>

  <body class="bg-slate-50 text-slate-800">
    <div class="pointer-events-none fixed inset-0 -z-10 bg-[radial-gradient(circle_at_10%_0%,rgba(57,197,187,0.2),transparent_42%),radial-gradient(circle_at_88%_8%,rgba(192,132,252,0.14),transparent_34%),linear-gradient(180deg,#f8fcfc_0%,#f1f8f7_50%,#f5f7ff_100%)]" />

    <BlogTopNav currentPath={Astro.url.pathname} />

    <main class="mx-auto w-full max-w-[1260px] px-4 pb-20 pt-24 md:pt-28">
      <ArticleHero
        title={title}
        description={description}
        pubDate={pubDate}
        updatedDate={updatedDate}
        heroImage={heroImage}
        category={category}
        tags={tags}
        readingMinutes={readingMinutes}
        wordCount={wordCount}
      />

      <section class="mx-auto mt-8 grid w-full max-w-[1100px] gap-6 xl:grid-cols-[minmax(0,1fr)_292px]">
        <article class="min-w-0">
          <div class="rounded-[26px] border border-slate-200/90 bg-white px-[22px] py-6 shadow-[0_14px_34px_rgba(15,23,42,0.08)]">
            <div id="article-content" class="article-prose prose-pre:m-0">
              <slot />
            </div>
          </div>
          <MarkdownCodeEnhancer client:load containerSelector="#article-content" />
        </article>

        <aside class="space-y-4 xl:sticky xl:top-[88px] xl:max-h-[calc(100vh-104px)] xl:overflow-y-auto xl:pr-1">
          {headings.length > 0 && <ReadingToc client:load headings={headings} />}
          <ArticleMeta
            pubDate={pubDate}
            updatedDate={updatedDate}
            readingMinutes={readingMinutes}
            wordCount={wordCount}
            headingsCount={tocHeadingCount}
            tags={tags}
          />
        </aside>
      </section>

      <ArticleFooter prevPost={prevPost} nextPost={nextPost} relatedPosts={relatedPosts} />
    </main>

    <script is:inline>
      (() => {
        const topNav = document.querySelector('[data-blog-topnav]')
        if (!topNav) {
          return
        }

        const syncNavState = () => {
          topNav.classList.toggle('is-scrolled', window.scrollY > 14)
        }

        syncNavState()
        window.addEventListener('scroll', syncNavState, { passive: true })
      })()
    </script>
  </body>
</html>
