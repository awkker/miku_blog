---
import BaseHead from '../components/base/BaseHead.astro'
import BlogTopNav from '../components/blog/BlogTopNav.astro'
import GlobalToast from '../components/ui/GlobalToast.vue'
import MomentsBoard from '../components/moments/MomentsBoard.vue'
import { siteCopy } from '../content/copy'

const copy = siteCopy.momentsPage
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={copy.metaTitle} description={copy.metaDescription} />
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-800">
    <BlogTopNav currentPath={Astro.url.pathname} />
    <main class="relative min-h-screen overflow-hidden pt-14">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute inset-0 bg-[url('/picture/shuoshuo.jpg')] bg-cover bg-center bg-no-repeat opacity-[0.22]" />
        <div class="absolute inset-0 bg-white/12" />
        <div class="absolute left-[8%] top-[5%] h-[400px] w-[400px] rounded-full bg-[#39c5bb]/8 blur-[120px]" />
        <div class="absolute right-[6%] top-[10%] h-[350px] w-[350px] rounded-full bg-[#c084fc]/6 blur-[100px]" />
        <div class="absolute bottom-[15%] left-[25%] h-[280px] w-[280px] rounded-full bg-[#c084fc]/4 blur-[90px]" />
      </div>

      <header class="relative mx-auto max-w-3xl px-4 pb-4 pt-12 text-center sm:px-6 sm:pt-16 lg:px-8">
        <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white/60 px-4 py-1.5 text-xs tracking-[0.22em] text-slate-400">
          <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 fill-none stroke-current stroke-[1.8]" aria-hidden="true">
            <path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z" />
          </svg>
          {copy.heroBadge}
        </div>
        <h1 class="bg-gradient-to-r from-slate-800 via-[#c084fc] to-[#39c5bb] bg-clip-text text-4xl font-bold tracking-tight text-transparent sm:text-5xl">
          {copy.title}
        </h1>
        <p class="mx-auto mt-4 max-w-lg text-base leading-relaxed text-slate-500">
          {copy.description}
        </p>
        <nav class="mt-6 flex flex-wrap items-center justify-center gap-2.5" aria-label={copy.navAria}>
          <a
            href={copy.quickLinks[0].href}
            class="inline-flex items-center gap-1.5 rounded-xl border border-slate-200 bg-white/60 px-3.5 py-2 text-sm text-slate-500 transition hover:border-miku/40 hover:text-miku"
            aria-label={copy.quickLinks[0].ariaLabel}
          >
            <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 fill-none stroke-current stroke-[1.5]" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 016.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z" /></svg>
            {copy.quickLinks[0].label}
          </a>
          <a
            href={copy.quickLinks[1].href}
            class="inline-flex items-center gap-1.5 rounded-xl border border-slate-200 bg-white/60 px-3.5 py-2 text-sm text-slate-500 transition hover:border-miku/40 hover:text-miku"
            aria-label={copy.quickLinks[1].ariaLabel}
          >
            <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 fill-none stroke-current stroke-[1.5]" aria-hidden="true"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" /></svg>
            {copy.quickLinks[1].label}
          </a>
          <a
            href={copy.quickLinks[2].href}
            class="inline-flex items-center gap-1.5 rounded-xl border border-slate-200 bg-white/60 px-3.5 py-2 text-sm text-slate-500 transition hover:border-[#c084fc]/40 hover:text-[#c084fc]"
            aria-label={copy.quickLinks[2].ariaLabel}
          >
            <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 fill-none stroke-current stroke-[1.5]" aria-hidden="true"><path d="M10 13a5 5 0 007.07 0l2.12-2.12a5 5 0 00-7.07-7.07L10 5M14 11a5 5 0 00-7.07 0L4.81 13.12a5 5 0 007.07 7.07L14 19" /></svg>
            {copy.quickLinks[2].label}
          </a>
        </nav>
      </header>

      <div class="relative mx-auto max-w-3xl space-y-6 px-4 pb-20 sm:px-6 lg:px-8">
        <MomentsBoard client:load />
      </div>

      <GlobalToast client:load />
    </main>
  </body>
</html>
