---
import BaseHead from '../../components/base/BaseHead.astro'
import BlogTopNav from '../../components/blog/BlogTopNav.astro'
import LiquidGlassCard from '../../components/ui/LiquidGlassCard.vue'
import LatestMoments from '../../components/moments/LatestMoments.vue'
import BlogFeed from '../../components/blog/BlogFeed.vue'
import AuthorStats from '../../components/blog/AuthorStats.vue'
import SiteTrend from '../../components/blog/SiteTrend.vue'
import { siteCopy } from '../../content/copy'

const copy = siteCopy.blogIndex
const heroActionClasses = [
  'inline-flex items-center rounded-xl border border-[#c084fc]/45 bg-[#f3e8ff] px-4 py-2.5 text-sm font-semibold text-[#8b5cf6] transition hover:-translate-y-0.5 hover:border-[#c084fc]/70',
  'inline-flex items-center rounded-xl border border-white/50 bg-white/18 px-4 py-2.5 text-sm font-semibold text-[#99f6e4] transition hover:-translate-y-0.5 hover:bg-white/24',
  'inline-flex items-center rounded-xl border border-white/50 bg-white/12 px-4 py-2.5 text-sm font-semibold text-[#99f6e4] transition hover:-translate-y-0.5 hover:bg-white/18',
]

---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={copy.metaTitle} description={copy.metaDescription} />
  </head>
  <body class="bg-slate-100 text-slate-800">
    <div class="relative min-h-screen pt-14">
      <div class="pointer-events-none fixed inset-0 -z-10 bg-[radial-gradient(circle_at_top,rgba(57,197,187,0.22),transparent_46%),radial-gradient(circle_at_85%_18%,rgba(192,132,252,0.16),transparent_36%),linear-gradient(180deg,#f8fafc_0%,#eef2ff_100%)]" />
      <div id="scroll-progress" class="fixed left-0 top-14 z-[60] h-0.5 w-full bg-gradient-to-r from-[#c084fc] via-miku to-[#c084fc]" />
      <BlogTopNav currentPath={Astro.url.pathname} />

      <header class="relative overflow-hidden border-b border-white/60">
        <div class="absolute inset-0 bg-[url('/picture/bloglist.jpg')] bg-cover bg-center bg-no-repeat" />
        <div class="absolute inset-0 bg-gradient-to-br from-slate-950/42 via-slate-900/30 to-white/86" />
        <div class="pointer-events-none absolute -left-16 top-6 h-56 w-56 rounded-full bg-miku/24 blur-3xl" />
        <div class="pointer-events-none absolute -right-20 top-16 h-52 w-52 rounded-full bg-[#c084fc]/26 blur-3xl" />

        <div class="relative z-10 mx-auto max-w-[1320px] px-4 pb-12 pt-20 md:pt-24">
          <div class="grid gap-7 lg:grid-cols-[minmax(0,1fr)_330px] lg:items-end">
            <div class="space-y-5">
              <p class="inline-flex animate-fade-up rounded-full border border-white/40 bg-white/20 px-4 py-1 text-xs tracking-[0.24em] text-[#99f6e4] backdrop-blur">
                {copy.heroBadge}
              </p>
              <h1 class="animate-fade-up text-[clamp(2.3rem,6.1vw,4.3rem)] font-black tracking-[0.08em] text-[#39c5bb] drop-shadow-lg">
                {copy.heroTitle}
              </h1>
              <p class="max-w-2xl animate-fade-up text-base leading-relaxed text-[#b8fff8] md:text-lg">
                {copy.heroDescription}
              </p>

              <div class="animate-fade-up flex flex-wrap gap-2.5">
                {
                  copy.heroActions.map((action, index) => (
                <a
                  href={action.href}
                  class={heroActionClasses[index] ?? heroActionClasses[0]}
                >
                  {action.label}
                </a>
                  ))
                }
              </div>

              <div class="grid gap-3 animate-fade-up sm:grid-cols-3">
                {
                  copy.quickStats.map((stat) => (
                    <div class="rounded-2xl border border-white/45 bg-white/16 p-3 text-[#b8fff8] shadow-[0_10px_24px_rgba(15,23,42,0.18)] backdrop-blur-xl">
                      <p class="text-[11px] tracking-[0.16em] text-[#99f6e4]">{stat.label}</p>
                      <p class="mt-1 text-sm font-semibold">{stat.value}</p>
                    </div>
                  ))
                }
              </div>
            </div>

            <div class="hero-focus-card animate-fade-up rounded-2xl border border-white/50 bg-white/22 p-4 text-[#b8fff8] shadow-[0_18px_40px_rgba(15,23,42,0.22)] backdrop-blur-xl">
              <p class="text-xs tracking-[0.2em] text-[#99f6e4]">{copy.focusCard.badge}</p>
              <h2 class="mt-2 text-lg font-bold text-[#39c5bb]">{copy.focusCard.title}</h2>
              <p class="mt-2 text-sm leading-relaxed text-[#b8fff8]">
                {copy.focusCard.description}
              </p>
              <div class="mt-4 rounded-xl border border-white/30 bg-white/12 px-3 py-2.5 text-xs text-[#99f6e4]">
                {copy.focusCard.footnote}
              </div>
            </div>
          </div>
        </div>

        <a
          href="#content-start"
          class="group absolute bottom-4 left-1/2 z-20 -translate-x-1/2 rounded-full border border-white/40 bg-white/18 px-4 py-1.5 text-xs tracking-[0.18em] text-[#99f6e4] backdrop-blur transition hover:bg-white/24"
          aria-label={copy.scrollCue.ariaLabel}
        >
          <span class="inline-flex items-center gap-2">
            {copy.scrollCue.label}
            <span class="scroll-cue-dot h-1.5 w-1.5 rounded-full bg-[#39c5bb]" />
          </span>
        </a>
      </header>

      <main id="content-start" class="mx-auto mt-6 grid w-full max-w-[1320px] grid-cols-1 gap-8 px-4 pb-20 lg:grid-cols-[minmax(0,1fr)_320px]">
        <section id="latest-posts">
          <BlogFeed client:load />
        </section>

        <aside class="space-y-6">
          <LiquidGlassCard client:load padding="0px">
            <div class="relative overflow-hidden">
              <div class="h-20 bg-gradient-to-r from-[#39c5bb]/30 via-[#c084fc]/20 to-[#39c5bb]/25" />
              <div class="relative -mt-10 px-5 pb-5">
                <div class="author-avatar-ring mx-auto h-20 w-20 rounded-full p-[3px]">
                  <img
                    src="/picture/author.jpg"
                    alt={copy.authorCard.avatarAlt}
                    class="h-full w-full rounded-full border-2 border-white object-cover transition-transform duration-700 hover:rotate-[360deg]"
                  />
                </div>

                <div class="mt-3 text-center">
                  <h3 class="text-xl font-bold text-slate-900">{copy.authorCard.name}</h3>
                  <p class="mt-0.5 text-xs text-miku/70">{copy.authorCard.role}</p>
                  <p class="mt-2 text-sm leading-relaxed text-slate-500">{copy.authorCard.bio}</p>
                </div>

                <div class="mt-3 flex items-center justify-center gap-3 text-[11px] text-slate-400">
                  <span class="inline-flex items-center gap-1">
                    <svg viewBox="0 0 24 24" class="h-3 w-3 fill-none stroke-current stroke-[2]" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" /></svg>
                    {copy.authorCard.location}
                  </span>
                  <span class="h-0.5 w-0.5 rounded-full bg-slate-300" />
                  <span class="inline-flex items-center gap-1">
                    <svg viewBox="0 0 24 24" class="h-3 w-3 fill-none stroke-current stroke-[2]" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    {copy.authorCard.since}
                  </span>
                </div>

                <div class="mt-3 flex flex-wrap justify-center gap-1.5">
                  {copy.authorCard.skills.map((skill) => (
                    <span class="rounded-md border border-slate-200 bg-slate-50/80 px-2 py-0.5 text-[10px] font-medium text-slate-500">
                      {skill}
                    </span>
                  ))}
                </div>

                <div class="mt-4 flex items-center justify-center gap-2">
                  {copy.socialLinks.map((link) => (
                    <a
                      href={link.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex h-8 w-8 items-center justify-center rounded-lg border border-slate-200 bg-white/60 text-slate-400 transition duration-300 hover:border-miku/40 hover:text-miku hover:shadow-sm"
                      aria-label={link.label}
                    >
                      <svg viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current stroke-[1.8]" aria-hidden="true">
                        <path d={link.icon} />
                      </svg>
                    </a>
                  ))}
                </div>

                <div class="mt-4">
                  <AuthorStats client:load />
                </div>

                <a
                  href="/about"
                  class="mt-4 inline-flex w-full items-center justify-center rounded-xl border border-miku/35 bg-miku-soft px-3 py-2 text-xs font-semibold text-miku transition hover:border-miku/55"
                >
                  {copy.authorCard.aboutCta}
                </a>
              </div>
            </div>
          </LiquidGlassCard>

          <div class="glass-layer rounded-2xl p-4">
            <h3 class="text-sm font-semibold text-slate-900">{copy.nowTitle}</h3>
            <ul class="mt-3 space-y-2">
              {
                copy.nowItems.map((item) => (
                  <li class="rounded-lg border border-white/60 bg-white/66 px-3 py-2 text-xs leading-relaxed text-slate-600">{item}</li>
                ))
              }
            </ul>
          </div>

          <div class="glass-layer rounded-2xl p-4">
            <h3 class="text-sm font-semibold text-slate-900">{copy.playlistTitle}</h3>
            <ul class="mt-3 space-y-2 text-xs text-slate-600">
              {
                copy.playlist.map((song) => (
                  <li class="rounded-lg border border-white/60 bg-white/66 px-3 py-2">{song}</li>
                ))
              }
            </ul>
          </div>


          <div class="relative z-10 mb-4 overflow-hidden rounded-2xl border border-white/35 bg-white/20 p-4 shadow-md backdrop-blur-xl">
            <SiteTrend client:load />
          </div>

          <LiquidGlassCard client:load padding="20px">
            <LatestMoments client:load />
          </LiquidGlassCard>
        </aside>
      </main>

      <button
        id="back-to-top"
        type="button"
        class="fixed bottom-6 right-5 z-40 rounded-full border border-miku/35 bg-white/85 p-2.5 text-miku shadow-[0_12px_28px_rgba(15,23,42,0.18)] backdrop-blur transition hover:-translate-y-0.5 hover:border-miku/60"
        aria-label={copy.backToTopAria}
      >
        <svg viewBox="0 0 24 24" class="h-4.5 w-4.5 fill-none stroke-current stroke-[2]"><path d="M18 15l-6-6-6 6" /></svg>
      </button>
    </div>

    <script is:inline>
      const progressBar = document.getElementById('scroll-progress')
      const backToTop = document.getElementById('back-to-top')
      const topNav = document.querySelector('[data-blog-topnav]')

      const updateScrollUI = () => {
        const scrollTop = window.scrollY || document.documentElement.scrollTop
        const maxScroll = document.documentElement.scrollHeight - window.innerHeight
        const ratio = maxScroll > 0 ? Math.min(1, scrollTop / maxScroll) : 0

        if (progressBar) {
          progressBar.style.transform = `scaleX(${ratio})`
        }

        if (backToTop) {
          backToTop.classList.toggle('is-visible', scrollTop > 520)
        }

        if (topNav) {
          topNav.classList.toggle('is-scrolled', scrollTop > 32)
        }
      }

      window.addEventListener('scroll', updateScrollUI, { passive: true })
      window.addEventListener('resize', updateScrollUI, { passive: true })
      updateScrollUI()

      backToTop?.addEventListener('click', () => {
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
        window.scrollTo({ top: 0, behavior: prefersReducedMotion ? 'auto' : 'smooth' })
      })
    </script>
  </body>
</html>

<style>
  @keyframes ring-rotate {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  .author-avatar-ring {
    background: conic-gradient(#39c5bb, #c084fc, #39c5bb);
    animation: ring-rotate 6s linear infinite;
  }
  @keyframes scroll-cue {
    0%, 100% { transform: translateY(0); opacity: 0.9; }
    50% { transform: translateY(4px); opacity: 0.35; }
  }
  .scroll-cue-dot {
    animation: scroll-cue 1.6s ease-in-out infinite;
  }
  #scroll-progress {
    transform-origin: 0 50%;
    transform: scaleX(0);
    transition: transform 120ms linear;
  }
  .blog-card {
    transform: translateY(0);
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.5s ease, border-color 0.5s ease;
  }
  .blog-card:hover {
    transform: translateY(-4px);
  }
  #back-to-top {
    opacity: 0;
    pointer-events: none;
    transform: translateY(10px);
  }
  #back-to-top.is-visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }
</style>
