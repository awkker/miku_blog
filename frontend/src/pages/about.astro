---
import { getCollection } from 'astro:content'
import BaseHead from '../components/base/BaseHead.astro'
import BlogTopNav from '../components/blog/BlogTopNav.astro'
import LiquidGlassCard from '../components/ui/LiquidGlassCard.vue'
import AboutGithubProfile from '../components/about/AboutGithubProfile.vue'
import { siteCopy } from '../content/copy'

const copy = siteCopy.aboutPage
const postCount = (await getCollection('blog')).length
const heroActionClasses = [
  'inline-flex items-center rounded-xl border border-miku/40 bg-miku-soft px-4 py-2.5 text-sm font-semibold text-miku transition hover:-translate-y-0.5 hover:border-miku/60',
  'inline-flex items-center rounded-xl border border-slate-200 bg-white/70 px-4 py-2.5 text-sm font-semibold text-slate-600 transition hover:-translate-y-0.5 hover:border-[#c084fc]/45 hover:text-[#8b5cf6]',
  'inline-flex items-center rounded-xl border border-slate-200 bg-white/70 px-4 py-2.5 text-sm font-semibold text-slate-600 transition hover:-translate-y-0.5 hover:border-miku/40 hover:text-miku',
]

const identityTags = copy.identityTags
const heroActions = copy.heroActions

const nowItems = copy.nowItems
const introCards = copy.introCards

const milestones = copy.milestones

const capabilityGroups = copy.capabilityGroups

const featuredProjects = copy.featuredProjects

const writingMap = copy.writingMap

const monthlyGoals = copy.monthlyGoals
const listeningNow = copy.listeningNow

const githubUsername = copy.githubUsername

const socialLinks = copy.socialLinks
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={copy.metaTitle} description={copy.metaDescription} />
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-800">
    <BlogTopNav currentPath={Astro.url.pathname} />
    <div id="scroll-progress" class="fixed left-0 top-14 z-[60] h-0.5 w-full bg-gradient-to-r from-miku via-[#c084fc] to-miku" />

    <main class="relative overflow-hidden pt-14">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute inset-0 bg-[url('/picture/aboutme.png')] bg-cover bg-center bg-no-repeat opacity-[0.22]" />
        <div class="absolute inset-0 bg-white/12" />
        <div class="absolute left-[8%] top-[4%] h-[360px] w-[360px] rounded-full bg-[#39c5bb]/10 blur-[120px]" />
        <div class="absolute right-[4%] top-[9%] h-[320px] w-[320px] rounded-full bg-[#c084fc]/8 blur-[100px]" />
        <div class="absolute bottom-[18%] left-[30%] h-[280px] w-[280px] rounded-full bg-[#c084fc]/6 blur-[90px]" />
      </div>

      <div class="relative z-10 space-y-4 pb-20 sm:space-y-5">
      <section class="relative mx-auto max-w-[1320px] px-4 pt-12 sm:px-6 lg:px-8 lg:pt-16">
        <div class="grid gap-6 lg:grid-cols-[1.1fr_360px]">
          <LiquidGlassCard client:visible padding="30px" maxWidth="100%">
            <div class="space-y-5">
              <p class="inline-flex rounded-full border border-white/60 bg-white/58 px-4 py-1 text-xs tracking-[0.18em] text-slate-500">
                {copy.heroBadge}
              </p>
              <h1 class="bg-gradient-to-r from-slate-900 via-[#39c5bb] to-[#c084fc] bg-clip-text text-[clamp(2rem,4.8vw,3.8rem)] font-black tracking-tight text-transparent">
                {copy.heroTitle}
              </h1>
              <p class="max-w-3xl text-base leading-relaxed text-slate-600 sm:text-lg">
                {copy.heroDescription}
              </p>

              <div class="flex flex-wrap gap-2">
                {
                  identityTags.map((tag) => (
                    <span class="rounded-full border border-slate-200 bg-white/70 px-3 py-1 text-xs font-medium text-slate-600">
                      {tag}
                    </span>
                  ))
                }
              </div>

              <div class="flex flex-wrap gap-2.5 pt-1">
                {
                  heroActions.map((action, index) => (
                <a
                  href={action.href}
                  class={heroActionClasses[index] ?? heroActionClasses[0]}
                >
                  {action.label}
                </a>
                  ))
                }
              </div>

              <div class="grid gap-2.5 pt-2 sm:grid-cols-3">
                <div class="rounded-xl border border-white/65 bg-white/62 px-3 py-2.5">
                  <p class="text-xs text-slate-400">{copy.stats.postsLabel}</p>
                  <p class="mt-1 text-lg font-bold text-slate-900">{postCount}</p>
                </div>
                <div class="rounded-xl border border-white/65 bg-white/62 px-3 py-2.5">
                  <p class="text-xs text-slate-400">{copy.stats.focusLabel}</p>
                  <p class="mt-1 text-sm font-semibold text-slate-800">{copy.stats.focusValue}</p>
                </div>
                <div class="rounded-xl border border-white/65 bg-white/62 px-3 py-2.5">
                  <p class="text-xs text-slate-400">{copy.stats.statusLabel}</p>
                  <p class="mt-1 text-sm font-semibold text-slate-800">{copy.stats.statusValue}</p>
                </div>
              </div>
            </div>
          </LiquidGlassCard>

          <LiquidGlassCard client:visible padding="24px" maxWidth="100%">
            <div class="space-y-4">
              <div class="flex items-center gap-3">
                <img
                  src="/picture/author.jpg"
                  alt={copy.profileCard.avatarAlt}
                  class="h-14 w-14 rounded-xl border border-slate-200 object-cover"
                />
                <div>
                  <p class="text-base font-semibold text-slate-900">{copy.profileCard.name}</p>
                  <p class="text-xs text-slate-500">{copy.profileCard.role}</p>
                </div>
              </div>
              <div class="rounded-xl border border-white/65 bg-white/58 px-3 py-2.5">
                <p class="text-xs tracking-[0.14em] text-miku">{copy.profileCard.nowTitle}</p>
                <ul class="mt-2 space-y-2 text-xs text-slate-600">
                  {
                    nowItems.map((item) => (
                      <li class="flex items-start gap-2">
                        <span class="mt-1 h-1.5 w-1.5 rounded-full bg-miku" />
                        <span>{item}</span>
                      </li>
                    ))
                  }
                </ul>
              </div>
              <blockquote class="rounded-xl border border-white/65 bg-white/58 px-3 py-2.5 text-sm leading-relaxed text-slate-600">
                {copy.profileCard.quote}
              </blockquote>
            </div>
          </LiquidGlassCard>
        </div>
      </section>

      <section id="github" class="relative mx-auto max-w-[1320px] px-4 sm:px-6 lg:px-8">
        <AboutGithubProfile client:visible githubUsername={githubUsername} />
      </section>

      <section class="relative mx-auto max-w-[1320px] px-4 sm:px-6 lg:px-8">
        <div class="grid gap-4 md:grid-cols-3">
          {
            introCards.map((card) => (
              <LiquidGlassCard client:visible padding="20px" maxWidth="100%">
                <h2 class="text-sm font-semibold text-slate-900">{card.title}</h2>
                <p class="mt-2 text-sm leading-relaxed text-slate-600">{card.description}</p>
              </LiquidGlassCard>
            ))
          }
        </div>
      </section>

      <section id="timeline" class="relative mx-auto max-w-[1320px] px-4 sm:px-6 lg:px-8">
        <LiquidGlassCard client:visible padding="24px" maxWidth="100%">
          <div class="mb-4">
            <h2 class="text-xl font-bold text-slate-900">{copy.timeline.title}</h2>
            <p class="mt-1 text-sm text-slate-500">{copy.timeline.subtitle}</p>
          </div>
          <ol class="timeline-list relative space-y-4 pl-5">
            {
              milestones.map((item) => (
                <li class="relative">
                  <span class="absolute -left-[21px] top-2 h-3 w-3 rounded-full border border-white bg-miku shadow-[0_0_0_3px_rgba(57,197,187,0.14)]" />
                  <div class="rounded-xl border border-white/65 bg-white/62 p-4">
                    <div class="flex flex-wrap items-center justify-between gap-2">
                    <h3 class="text-base font-semibold text-slate-900">{item.title}</h3>
                    <span class="rounded-full bg-miku-soft px-2.5 py-0.5 text-xs font-semibold text-miku">{item.year}</span>
                  </div>
                  <p class="mt-2 text-sm leading-relaxed text-slate-600">{item.summary}</p>
                    <p class="mt-1.5 text-xs text-slate-500">{copy.timeline.resultPrefix}{item.result}</p>
                  </div>
                </li>
              ))
            }
          </ol>
        </LiquidGlassCard>
      </section>

      <section id="skills" class="relative mx-auto max-w-[1320px] px-4 sm:px-6 lg:px-8">
        <div class="grid gap-4 md:grid-cols-3">
          {
            capabilityGroups.map((group, index) => (
              <LiquidGlassCard client:visible padding="20px" maxWidth="100%">
                <h3 class="text-base font-semibold text-slate-900">{group.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-slate-600">{group.desc}</p>
                <div class="mt-3 flex flex-wrap gap-1.5">
                  {
                    group.stack.map((item) => (
                      <span
                        class:list={[
                          'rounded-full border px-2.5 py-1 text-xs',
                          index === 0
                            ? 'border-miku/35 bg-miku-soft text-miku'
                            : index === 1
                              ? 'border-slate-200 bg-white/70 text-slate-600'
                              : 'border-[#c084fc]/35 bg-[#f3e8ff] text-[#8b5cf6]',
                        ]}
                      >
                        {item}
                      </span>
                    ))
                  }
                </div>
              </LiquidGlassCard>
            ))
          }
        </div>
      </section>

      <section id="projects" class="relative mx-auto max-w-[1320px] px-4 sm:px-6 lg:px-8">
        <div class="mb-3">
          <h2 class="text-xl font-bold text-slate-900">{copy.projectsSection.title}</h2>
          <p class="mt-1 text-sm text-slate-500">{copy.projectsSection.subtitle}</p>
        </div>
        <div class="grid gap-4 lg:grid-cols-3">
          {
            featuredProjects.map((project) => (
              <LiquidGlassCard client:visible padding="20px" maxWidth="100%">
                <h3 class="text-base font-semibold text-slate-900">{project.name}</h3>
                <p class="mt-2 text-sm text-slate-600">{project.focus}</p>
                <p class="mt-2 text-xs leading-relaxed text-slate-500">{project.role}</p>
                <p class="mt-2 rounded-lg border border-white/70 bg-white/65 px-2.5 py-2 text-xs text-slate-600">{project.metric}</p>
                <a
                  href={project.href}
                  class="mt-3 inline-flex items-center rounded-lg border border-miku/35 bg-miku-soft px-3 py-1.5 text-xs font-semibold text-miku transition hover:border-miku/55"
                >
                  {copy.projectsSection.cta}
                </a>
              </LiquidGlassCard>
            ))
          }
        </div>
      </section>

      <section id="writing-map" class="relative mx-auto max-w-[1320px] px-4 sm:px-6 lg:px-8">
        <div class="mb-3">
          <h2 class="text-xl font-bold text-slate-900">{copy.writingMapSection.title}</h2>
          <p class="mt-1 text-sm text-slate-500">{copy.writingMapSection.subtitle}</p>
        </div>
        <div class="grid gap-4 md:grid-cols-3">
          {
            writingMap.map((item, index) => (
              <LiquidGlassCard client:visible padding="20px" maxWidth="100%">
                <p class="text-xs tracking-[0.14em] text-slate-400">{copy.writingMapSection.pathPrefix} 0{index + 1}</p>
                <h3 class="mt-1 text-base font-semibold text-slate-900">{item.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-slate-600">{item.desc}</p>
                <a
                  href={item.href}
                  class="mt-3 inline-flex items-center rounded-lg border border-slate-200 bg-white/75 px-3 py-1.5 text-xs font-semibold text-slate-600 transition hover:border-[#c084fc]/40 hover:text-[#8b5cf6]"
                >
                  {copy.writingMapSection.cta}
                </a>
              </LiquidGlassCard>
            ))
          }
        </div>
      </section>

      <section class="relative mx-auto max-w-[1320px] px-4 sm:px-6 lg:px-8">
        <div class="grid gap-4 md:grid-cols-3">
          <LiquidGlassCard client:visible padding="20px" maxWidth="100%">
            <h3 class="text-sm font-semibold text-slate-900">{copy.monthlyGoalsTitle}</h3>
            <ul class="mt-3 space-y-2">
              {
                monthlyGoals.map((goal) => (
                  <li class="flex items-start gap-2 text-xs text-slate-600">
                    <span class="mt-1 h-1.5 w-1.5 rounded-full bg-miku" />
                    <span>{goal}</span>
                  </li>
                ))
              }
            </ul>
          </LiquidGlassCard>

          <LiquidGlassCard client:visible padding="20px" maxWidth="100%">
            <h3 class="text-sm font-semibold text-slate-900">{copy.listeningTitle}</h3>
            <ul class="mt-3 space-y-2 text-xs text-slate-600">
              {
                listeningNow.map((song) => (
                  <li class="rounded-lg border border-white/65 bg-white/62 px-2.5 py-2">
                    {song}
                  </li>
                ))
              }
            </ul>
          </LiquidGlassCard>

          <LiquidGlassCard client:visible padding="20px" maxWidth="100%">
            <h3 class="text-sm font-semibold text-slate-900">{copy.signature.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">
              {copy.signature.description}
            </p>
            <p class="mt-2 text-xs text-slate-500">{copy.signature.footer}</p>
          </LiquidGlassCard>
        </div>
      </section>

      <section class="relative mx-auto max-w-[1320px] px-4 sm:px-6 lg:px-8">
        <LiquidGlassCard client:visible padding="26px" maxWidth="100%">
          <div class="flex flex-col gap-5 md:flex-row md:items-center md:justify-between">
            <div>
              <h2 class="text-lg font-bold text-slate-900">{copy.contactSection.title}</h2>
              <p class="mt-1 text-sm text-slate-500">{copy.contactSection.subtitle}</p>
            </div>
            <div class="flex flex-wrap gap-2">
              <a
                href={copy.contactSection.emailHref}
                class="inline-flex items-center rounded-xl border border-miku/40 bg-miku-soft px-4 py-2 text-sm font-semibold text-miku transition hover:border-miku/60"
              >
                {copy.contactSection.emailButton}
              </a>
              <a
                href={`https://github.com/${githubUsername}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center rounded-xl border border-slate-200 bg-white/75 px-4 py-2 text-sm font-semibold text-slate-600 transition hover:border-[#c084fc]/40 hover:text-[#8b5cf6]"
              >
                {copy.contactSection.githubButton}
              </a>
              {
                socialLinks.map((link) => (
                  <a
                    href={link.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center rounded-xl border border-slate-200 bg-white/75 px-4 py-2 text-sm font-semibold text-slate-600 transition hover:-translate-y-0.5 hover:border-[#c084fc]/40 hover:text-[#8b5cf6]"
                  >
                    {link.label}
                  </a>
                ))
              }
            </div>
          </div>
        </LiquidGlassCard>
      </section>
      </div>
    </main>

    <button
      id="back-to-top"
      type="button"
      class="fixed bottom-6 right-5 z-40 rounded-full border border-miku/35 bg-white/85 p-2.5 text-miku shadow-[0_12px_28px_rgba(15,23,42,0.18)] backdrop-blur transition hover:-translate-y-0.5 hover:border-miku/60"
      aria-label={copy.backToTopAria}
    >
      <svg viewBox="0 0 24 24" class="h-4.5 w-4.5 fill-none stroke-current stroke-[2]"><path d="M18 15l-6-6-6 6" /></svg>
    </button>

    <script is:inline>
      const progressBar = document.getElementById('scroll-progress')
      const backToTop = document.getElementById('back-to-top')
      const topNav = document.querySelector('[data-blog-topnav]')

      const updateScrollUI = () => {
        const scrollTop = window.scrollY || document.documentElement.scrollTop
        const maxScroll = document.documentElement.scrollHeight - window.innerHeight
        const ratio = maxScroll > 0 ? Math.min(1, scrollTop / maxScroll) : 0

        if (progressBar) {
          progressBar.style.transform = `scaleX(${ratio})`
        }

        if (backToTop) {
          backToTop.classList.toggle('is-visible', scrollTop > 460)
        }

        if (topNav) {
          topNav.classList.toggle('is-scrolled', scrollTop > 24)
        }
      }

      window.addEventListener('scroll', updateScrollUI, { passive: true })
      window.addEventListener('resize', updateScrollUI, { passive: true })
      updateScrollUI()

      backToTop?.addEventListener('click', () => {
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
        window.scrollTo({ top: 0, behavior: prefersReducedMotion ? 'auto' : 'smooth' })
      })
    </script>
  </body>
</html>

<style>
  .timeline-list::before {
    content: '';
    position: absolute;
    left: 9px;
    top: 8px;
    bottom: 8px;
    width: 1px;
    pointer-events: none;
    background: linear-gradient(
      to bottom,
      rgba(57, 197, 187, 0.6),
      rgba(192, 132, 252, 0.55),
      rgba(57, 197, 187, 0.25)
    );
  }

  #scroll-progress {
    transform-origin: 0 50%;
    transform: scaleX(0);
    transition: transform 120ms linear;
  }

  #back-to-top {
    opacity: 0;
    pointer-events: none;
    transform: translateY(10px);
  }

  #back-to-top.is-visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }
</style>
