---
import BaseHead from '../components/base/BaseHead.astro'
import LiquidGlassCard from '../components/ui/LiquidGlassCard.vue'
import SystemClock from '../components/home/SystemClock.vue'
import TypewriterSubtitle from '../components/home/TypewriterSubtitle.vue'
import MusicPlayer from '../components/home/MusicPlayer.vue'
import HeroTitle from '../components/home/HeroTitle.vue'
import WeatherDisplay from '../components/home/WeatherDisplay.vue'
import HeroParallax from '../components/home/HeroParallax.vue'
import HeroShuffleBtn from '../components/home/HeroShuffleBtn.vue'
import { siteCopy } from '../content/copy'

const dockItems = siteCopy.home.dockItems

const iconPaths: Record<string, string> = {
  person:
    'M12 12c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zm0 2c-3.87 0-7 2.01-7 4.5V21h14v-2.5c0-2.49-3.13-4.5-7-4.5z',
  book: 'M18 2H8a3 3 0 0 0-3 3v14a3 3 0 0 1 3-3h10V2zm2 16H8a1 1 0 0 0-1 1v1h13v-2z',
  moments: 'M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z',
  message: 'M4 5h16a2 2 0 012 2v9a2 2 0 01-2 2H8l-4 3v-3H4a2 2 0 01-2-2V7a2 2 0 012-2zm4 5h8M8 13h6',
  link: 'M10 13a5 5 0 007.07 0l2.12-2.12a5 5 0 10-7.07-7.07L10 5M14 11a5 5 0 00-7.07 0L4.81 13.12a5 5 0 007.07 7.07L14 19',
  login: 'M10 17l5-5-5-5M15 12H3M17 4h2a2 2 0 012 2v12a2 2 0 01-2 2h-2',
  admin: 'M4 5h16v14H4V5zm4 3h8M8 11h8M8 15h5',
  shuffle: 'M4 4l5 5M15 4l5 5M4 20l5-5M15 20l5-5M12 2v4M12 18v4M2 12h4M18 12h4',
}
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={siteCopy.home.metaTitle} description={siteCopy.home.metaDescription} />
  </head>
  <body class="overflow-hidden bg-slate-900 text-[#39c5bb]">
    <main class="relative h-screen w-screen overflow-hidden">
      <HeroParallax client:load />

      <header class="absolute left-0 top-0 z-20 flex h-8 w-full items-center justify-between border-b border-white/30 bg-white/35 px-4 text-sm font-medium text-[#39c5bb]/90 backdrop-blur-none">
        <div class="flex items-center gap-2 text-xs tracking-[0.2em]">
          <img src="/picture/logo-64.webp" alt={siteCopy.brand.logoAlt} class="h-4 w-4 rounded-sm object-cover" width="16" height="16" loading="eager" decoding="async" fetchpriority="high" />
          <span class="rounded bg-white/20 px-2 py-0.5">{siteCopy.brand.text}</span>
        </div>

        <div class="flex items-center gap-3 text-[11px]">
          <MusicPlayer client:load />
          <WeatherDisplay client:load />
          <SystemClock client:load />
        </div>
      </header>

      <section class="relative z-10 flex h-full flex-col items-center justify-center px-4 text-center">
        <h1 class="hero-title animate-fade-up text-[clamp(2.9rem,7.4vw,5.6rem)] tracking-[0.03em]">
          <span class="hero-text"><HeroTitle client:load text={siteCopy.home.heroTitle} /></span>
        </h1>
        <TypewriterSubtitle
          client:load
          text={siteCopy.home.heroSubtitle}
        />
      </section>

      <div class="absolute bottom-4 left-1/2 z-20 -translate-x-1/2">
        <LiquidGlassCard client:load width="auto" maxWidth="max-content" padding="10px 14px" borderRadius={16}>
          <ul class="flex items-end gap-1.5 sm:gap-2">
            {
              dockItems.map((item, index) => (
                <li>
                  <a
                    href={item.href}
                    data-auth-visible={item.auth}
                    class:list={[
                      'group flex w-12 flex-col items-center gap-1 rounded-2xl py-2 text-[10px] text-[#39c5bb]/90 transition duration-300 hover:scale-110 hover:bg-white/20 sm:w-16 sm:text-xs sm:hover:scale-125',
                      item.auth && 'hidden',
                      index === 1 && 'animate-dock-float',
                    ]}
                  >
                    <span class="flex h-8 w-8 items-center justify-center rounded-xl border border-white/30 bg-white/15 sm:h-9 sm:w-9">
                      <svg viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current stroke-[1.5] sm:h-5 sm:w-5">
                        <path d={iconPaths[item.icon]} />
                      </svg>
                    </span>
                    <span>{item.name}</span>
                    <span class:list={['h-1.5 w-1.5 rounded-full bg-white', index === 1 ? 'opacity-100' : 'opacity-0']} />
                  </a>
                </li>
              ))
            }
            <li>
              <HeroShuffleBtn client:load />
            </li>
          </ul>
        </LiquidGlassCard>
      </div>
    </main>
  </body>
</html>

<script is:inline>
  function updateAuthVisibleLinks() {
    const token = window.localStorage.getItem('miku_blog_token');
    const authed = Boolean(token);
    const links = document.querySelectorAll('[data-auth-visible]');

    links.forEach((el) => {
      const mode = el.getAttribute('data-auth-visible');
      const shouldShow = (mode === 'authed' && authed) || (mode === 'guest' && !authed);
      el.classList.toggle('hidden', !shouldShow);
    });
  }

  updateAuthVisibleLinks();
  window.addEventListener('storage', updateAuthVisibleLinks);
</script>

<style>
  .hero-title {
    font-family: 'Noto Serif SC', 'Noto Serif JP', 'Songti SC', 'STSong', serif;
    font-weight: 700;
    line-height: 1.08;
    position: relative;
  }

  .hero-text {
    background: linear-gradient(
      90deg,
      #b4f0ea,
      #60e8dc 25%,
      #ffffff 50%,
      #60e8dc 75%,
      #b4f0ea
    );
    background-size: 200% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: gradient-flow 5s ease-in-out infinite alternate;
    position: relative;
    display: inline-block;
  }

  @keyframes gradient-flow {
    0% { background-position: 0% 50%; }
    100% { background-position: 200% 50%; }
  }
</style>
