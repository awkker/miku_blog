---
import AdminSidebar from '../components/admin/AdminSidebar.vue'
import AdminContentHeader from '../components/admin/AdminContentHeader.vue'
import GlobalToast from '../components/ui/GlobalToast.vue'

interface Props {
  activeKey?: string
  pageTitle?: string
}

const { activeKey = 'dashboard', pageTitle = '仪表盘' } = Astro.props
---

<main class="relative min-h-screen bg-slate-50 text-slate-900">
  <div class="relative mx-auto flex max-w-[1400px] gap-0 px-4 py-6 sm:px-6 lg:px-8">
    <AdminSidebar client:load active-key={activeKey} />

    <section class="min-w-0 flex-1 space-y-5 lg:pl-5">
      <AdminContentHeader client:load page-title={pageTitle} />
      <slot />
    </section>
  </div>

  <GlobalToast client:load />
</main>
