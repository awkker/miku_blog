---
import { Image } from 'astro:assets'
import { getCollection } from 'astro:content'
import BaseHead from '../../components/base/BaseHead.astro'
import BlogTopNav from '../../components/blog/BlogTopNav.astro'
import FormattedDate from '../../components/base/FormattedDate.astro'
import LiquidGlassCard from '../../components/ui/LiquidGlassCard.vue'

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
)

const tabs = ['最新', '精选', '随笔']
const tags = ['前端设计', 'Astro', '生活观察', '代码笔记']

const hotList = posts.slice(0, 7).map((post, index) => ({
  title: post.data.title,
  href: `/blog/${post.id}/`,
  heat: 926 - index * 97,
}))
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title="Miku Blog" description="博客主页" />
  </head>
  <body class="bg-slate-100 text-slate-800">
    <div class="relative min-h-screen">
      <div class="pointer-events-none fixed inset-0 -z-10 bg-[radial-gradient(circle_at_top,rgba(102,205,170,0.22),transparent_45%),linear-gradient(180deg,#f8fafc_0%,#eef2ff_100%)]" />
      <BlogTopNav currentPath={Astro.url.pathname} />

      <header class="relative h-[40vh] min-h-[280px] overflow-hidden">
        <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=2200&q=80')] bg-cover bg-center" />
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-slate-900/25 to-white/90" />
        <div class="relative z-10 flex h-full flex-col items-center justify-center gap-4 text-center text-white">
          <p class="rounded-full bg-white/20 px-4 py-1 text-xs tracking-[0.26em] backdrop-blur">MIKU SPACE</p>
          <h1 class="text-[clamp(2.5rem,7vw,4.6rem)] font-black tracking-[0.08em] drop-shadow-lg">NanaMiku Blog</h1>
          <p class="text-base text-white/90">文字是风，代码是海，愿你在此停留片刻。</p>
        </div>
      </header>

      <main class="mx-auto -mt-14 grid w-full max-w-[1320px] grid-cols-1 gap-8 px-4 pb-20 lg:grid-cols-[minmax(0,1fr)_320px]">
        <section class="space-y-6">
          <div class="glass-layer rounded-2xl p-3">
            <div class="flex flex-wrap gap-2">
              {
                tabs.map((tab, index) => (
                  <button
                    type="button"
                    class:list={[
                      'rounded-xl border border-transparent px-4 py-2 text-sm transition',
                      index === 0
                        ? 'border-miku/45 bg-miku-soft text-miku'
                        : 'bg-white/35 text-slate-600 hover:border-miku/30 hover:text-miku',
                    ]}
                  >
                    {tab}
                  </button>
                ))
              }
            </div>
          </div>

          <div class="grid grid-cols-1 gap-7 md:grid-cols-2">
            {
              posts.map((post, index) => (
                <article class="group overflow-hidden rounded-3xl border border-white/45 bg-white/70 shadow-lg backdrop-blur">
                  <a href={`/blog/${post.id}/`} class="block">
                    <div class="h-52 overflow-hidden">
                      {post.data.heroImage ? (
                        <Image
                          src={post.data.heroImage}
                          alt={post.data.title}
                          width={720}
                          height={420}
                          class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
                        />
                      ) : (
                        <img
                          src="https://images.unsplash.com/photo-1521572267360-ee0c2909d518?auto=format&fit=crop&w=1600&q=80"
                          alt={post.data.title}
                          class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
                        />
                      )}
                    </div>
                    <div class="space-y-3 px-5 py-5">
                      <span class="inline-flex rounded-full bg-miku-soft px-3 py-1 text-xs font-semibold text-miku">
                        {tags[index % tags.length]}
                      </span>
                      <h2 class="text-xl font-bold text-slate-900 transition group-hover:text-miku">{post.data.title}</h2>
                      <p class="overflow-hidden text-sm text-slate-500 [display:-webkit-box] [-webkit-box-orient:vertical] [-webkit-line-clamp:2]">
                        {post.data.description}
                      </p>
                      <p class="text-sm text-slate-400">
                        <FormattedDate date={post.data.pubDate} />
                      </p>
                    </div>
                  </a>
                </article>
              ))
            }
          </div>
        </section>

        <aside class="space-y-6">
          <LiquidGlassCard client:load class="rounded-3xl p-6">
            <div class="space-y-4 text-center">
              <img
                src="/picture/author.jpg"
                alt="博主头像"
                class="mx-auto h-24 w-24 rounded-full border-2 border-white/75 object-cover transition-transform duration-700 hover:rotate-[360deg]"
              />
              <div>
                <h3 class="text-xl font-bold text-slate-900">Nana Miku</h3>
                <p class="mt-1 text-sm text-slate-600">在代码与日常之间写一点温柔的记录。</p>
              </div>
              <div class="grid grid-cols-3 gap-3 text-center">
                <div class="rounded-xl bg-white/35 px-2 py-3">
                  <p class="text-lg font-bold text-slate-900">{posts.length}</p>
                  <p class="text-xs text-slate-500">文章</p>
                </div>
                <div class="rounded-xl bg-white/35 px-2 py-3">
                  <p class="text-lg font-bold text-slate-900">{tags.length}</p>
                  <p class="text-xs text-slate-500">分类</p>
                </div>
                <div class="rounded-xl bg-white/35 px-2 py-3">
                  <p class="text-lg font-bold text-slate-900">8.4k</p>
                  <p class="text-xs text-slate-500">访问</p>
                </div>
              </div>
            </div>
          </LiquidGlassCard>

          <LiquidGlassCard client:load class="rounded-3xl p-6">
            <h3 class="mb-4 text-sm font-bold tracking-[0.22em] text-slate-700">HOT RANKING</h3>
            <ul class="space-y-3">
              {
                hotList.map((item, index) => (
                  <li>
                    <a href={item.href} class="flex items-center gap-3 rounded-xl px-2 py-2 transition hover:bg-white/25">
                      <span
                        class:list={[
                          'w-6 text-center text-sm font-bold',
                          index === 0 && 'text-red-500',
                          index === 1 && 'text-orange-500',
                          index === 2 && 'text-amber-500',
                          index > 2 && 'text-slate-400',
                        ]}
                      >
                        {index + 1}
                      </span>
                      <span class="flex-1 truncate text-sm text-slate-700">{item.title}</span>
                      <span class="text-xs text-slate-400">{item.heat}</span>
                    </a>
                  </li>
                ))
              }
            </ul>
          </LiquidGlassCard>
        </aside>
      </main>
    </div>
  </body>
</html>
