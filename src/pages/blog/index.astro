---
import { Image } from 'astro:assets'
import { getCollection } from 'astro:content'
import BaseHead from '../../components/base/BaseHead.astro'
import BlogTopNav from '../../components/blog/BlogTopNav.astro'
import FormattedDate from '../../components/base/FormattedDate.astro'
import LiquidGlassCard from '../../components/ui/LiquidGlassCard.vue'
import LatestMoments from '../../components/moments/LatestMoments.vue'

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
)

const tabs = ['最新', '精选', '随笔', '热度']
const tags = ['前端设计', 'Astro', '生活观察', '代码笔记']

const socialLinks = [
  { label: 'GitHub', href: 'https://github.com', icon: 'M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22' },
  { label: 'Twitter', href: 'https://twitter.com', icon: 'M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z' },
  { label: 'Mail', href: 'mailto:hello@nanamiku.blog', icon: 'M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2zm16 2l-8 5-8-5' },
]
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title="Miku Blog" description="博客主页" />
  </head>
  <body class="bg-slate-100 text-slate-800">
    <div class="relative min-h-screen pt-14">
      <div class="pointer-events-none fixed inset-0 -z-10 bg-[radial-gradient(circle_at_top,rgba(57,197,187,0.22),transparent_45%),linear-gradient(180deg,#f8fafc_0%,#eef2ff_100%)]" />
      <BlogTopNav currentPath={Astro.url.pathname} />

      <header class="relative h-[40vh] min-h-[280px] overflow-hidden">
        <div class="absolute inset-0 bg-[url('/picture/bloglist.jpg')] bg-cover bg-center bg-no-repeat" />
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-slate-900/25 to-white/90" />
        <div class="relative z-10 flex h-full flex-col items-center justify-center gap-4 text-center text-white">
          <p class="rounded-full bg-white/20 px-4 py-1 text-xs tracking-[0.26em] backdrop-blur">MIKU SPACE</p>
          <h1 class="text-[clamp(2.5rem,7vw,4.6rem)] font-black tracking-[0.08em] drop-shadow-lg">NanaMiku Blog</h1>
          <p class="text-base text-white/90">文字是风，代码是海，愿你在此停留片刻。</p>
        </div>
      </header>

      <main class="mx-auto mt-6 grid w-full max-w-[1320px] grid-cols-1 gap-8 px-4 pb-20 lg:grid-cols-[minmax(0,1fr)_320px]">
        <section class="space-y-6">
          <div class="glass-layer rounded-2xl p-3">
            <div class="flex flex-wrap gap-2">
              {
                tabs.map((tab, index) => (
                  <button
                    type="button"
                    class:list={[
                      'rounded-xl border border-transparent px-4 py-2 text-sm transition',
                      index === 0
                        ? 'border-miku/45 bg-miku-soft text-miku'
                        : tab === '热度'
                          ? 'bg-white/35 text-slate-600 hover:border-orange-400/30 hover:text-orange-500'
                          : 'bg-white/35 text-slate-600 hover:border-miku/30 hover:text-miku',
                    ]}
                  >
                    {tab === '热度' && (
                      <svg viewBox="0 0 24 24" class="mr-1 inline-block h-3.5 w-3.5 fill-none stroke-current stroke-[2] align-[-2px]" aria-hidden="true">
                        <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
                      </svg>
                    )}
                    {tab}
                  </button>
                ))
              }
            </div>
          </div>

          <div class="grid grid-cols-1 gap-7 md:grid-cols-2">
            {
              posts.map((post, index) => (
                <article class="blog-card group relative overflow-hidden rounded-3xl border border-white/50 bg-white/70 shadow-lg backdrop-blur transition duration-500 hover:border-miku/25 hover:shadow-[0_16px_40px_rgba(57,197,187,0.12)]">
                  <a href={`/blog/${post.id}/`} class="block">
                    <div class="relative h-52 overflow-hidden">
                      {post.data.heroImage ? (
                        <Image
                          src={post.data.heroImage}
                          alt={post.data.title}
                          width={720}
                          height={420}
                          class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
                        />
                      ) : (
                        <img
                          src="https://images.unsplash.com/photo-1521572267360-ee0c2909d518?auto=format&fit=crop&w=1600&q=80"
                          alt={post.data.title}
                          class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
                        />
                      )}
                      <div class="absolute inset-0 bg-gradient-to-t from-black/20 via-transparent to-transparent opacity-0 transition duration-500 group-hover:opacity-100" />
                      <div class="absolute right-3 top-3 rounded-full bg-white/80 px-2.5 py-1 text-[10px] font-semibold text-slate-500 opacity-0 shadow-sm backdrop-blur-sm transition duration-500 group-hover:opacity-100">
                        {Math.ceil((post.data.description?.length || 100) / 50)} min read
                      </div>
                    </div>
                    <div class="space-y-3 px-5 py-5">
                      <div class="flex items-center gap-2">
                        <span class="inline-flex rounded-full bg-miku-soft px-3 py-1 text-xs font-semibold text-miku">
                          {tags[index % tags.length]}
                        </span>
                      </div>
                      <h2 class="text-xl font-bold text-slate-900 transition duration-300 group-hover:text-miku">{post.data.title}</h2>
                      <p class="overflow-hidden text-sm leading-relaxed text-slate-500 [display:-webkit-box] [-webkit-box-orient:vertical] [-webkit-line-clamp:2]">
                        {post.data.description}
                      </p>
                      <div class="flex items-center gap-3 text-sm text-slate-400">
                        <FormattedDate date={post.data.pubDate} />
                        <span class="h-0.5 w-0.5 rounded-full bg-slate-300" />
                        <span class="inline-flex items-center gap-1">
                          <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 fill-none stroke-current stroke-[1.5]" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
                          {926 - index * 97}
                        </span>
                      </div>
                    </div>
                  </a>
                </article>
              ))
            }
          </div>
        </section>

        <aside class="space-y-6">
          <!-- Author Card -->
          <LiquidGlassCard client:load padding="0px">
            <div class="relative overflow-hidden">
              <!-- Banner gradient -->
              <div class="h-20 bg-gradient-to-r from-[#39c5bb]/30 via-[#c084fc]/20 to-[#39c5bb]/25" />
              <div class="relative -mt-10 px-5 pb-5">
                <!-- Avatar with animated ring -->
                <div class="author-avatar-ring mx-auto h-20 w-20 rounded-full p-[3px]">
                  <img
                    src="/picture/author.jpg"
                    alt="博主头像"
                    class="h-full w-full rounded-full border-2 border-white object-cover transition-transform duration-700 hover:rotate-[360deg]"
                  />
                </div>

                <div class="mt-3 text-center">
                  <h3 class="text-xl font-bold text-slate-900">Nana Miku</h3>
                  <p class="mt-0.5 text-xs text-miku/70">Front-end Developer / Writer</p>
                  <p class="mt-2 text-sm leading-relaxed text-slate-500">在代码与日常之间写一点温柔的记录。</p>
                </div>

                <!-- Location & since -->
                <div class="mt-3 flex items-center justify-center gap-3 text-[11px] text-slate-400">
                  <span class="inline-flex items-center gap-1">
                    <svg viewBox="0 0 24 24" class="h-3 w-3 fill-none stroke-current stroke-[2]" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" /></svg>
                    China
                  </span>
                  <span class="h-0.5 w-0.5 rounded-full bg-slate-300" />
                  <span class="inline-flex items-center gap-1">
                    <svg viewBox="0 0 24 24" class="h-3 w-3 fill-none stroke-current stroke-[2]" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    Since 2026
                  </span>
                </div>

                <!-- Skill tags -->
                <div class="mt-3 flex flex-wrap justify-center gap-1.5">
                  {['Astro', 'Vue', 'Go', 'TypeScript', 'Tailwind'].map((skill) => (
                    <span class="rounded-md border border-slate-200 bg-slate-50/80 px-2 py-0.5 text-[10px] font-medium text-slate-500">
                      {skill}
                    </span>
                  ))}
                </div>

                <!-- Social links -->
                <div class="mt-4 flex items-center justify-center gap-2">
                  {socialLinks.map((link) => (
                    <a
                      href={link.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex h-8 w-8 items-center justify-center rounded-lg border border-slate-200 bg-white/60 text-slate-400 transition duration-300 hover:border-miku/40 hover:text-miku hover:shadow-sm"
                      aria-label={link.label}
                    >
                      <svg viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current stroke-[1.8]" aria-hidden="true">
                        <path d={link.icon} />
                      </svg>
                    </a>
                  ))}
                </div>

                <!-- Stats -->
                <div class="mt-4 grid grid-cols-3 gap-2.5 text-center">
                  <div class="rounded-xl border border-slate-100 bg-white/50 px-2 py-2.5 transition duration-300 hover:border-miku/20 hover:shadow-sm">
                    <p class="text-lg font-bold text-slate-900">{posts.length}</p>
                    <p class="text-[11px] text-slate-500">文章</p>
                  </div>
                  <div class="rounded-xl border border-slate-100 bg-white/50 px-2 py-2.5 transition duration-300 hover:border-miku/20 hover:shadow-sm">
                    <p class="text-lg font-bold text-slate-900">{tags.length}</p>
                    <p class="text-[11px] text-slate-500">分类</p>
                  </div>
                  <div class="rounded-xl border border-slate-100 bg-white/50 px-2 py-2.5 transition duration-300 hover:border-miku/20 hover:shadow-sm">
                    <p class="text-lg font-bold text-slate-900">8.4k</p>
                    <p class="text-[11px] text-slate-500">访问</p>
                  </div>
                </div>
              </div>
            </div>
          </LiquidGlassCard>

          <!-- Latest Moments -->
          <LiquidGlassCard client:load padding="20px">
            <LatestMoments client:load />
          </LiquidGlassCard>
        </aside>
      </main>
    </div>
  </body>
</html>

<style>
  @keyframes ring-rotate {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  .author-avatar-ring {
    background: conic-gradient(#39c5bb, #c084fc, #39c5bb);
    animation: ring-rotate 6s linear infinite;
  }
  .blog-card {
    transform: translateY(0);
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.5s ease, border-color 0.5s ease;
  }
  .blog-card:hover {
    transform: translateY(-4px);
  }
</style>
