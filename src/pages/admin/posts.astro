---
import BaseHead from '../../components/base/BaseHead.astro'
import AdminRouteGuard from '../../components/admin/AdminRouteGuard.astro'
import AdminSectionPlaceholder from '../../components/admin/AdminSectionPlaceholder.vue'
import AdminLayout from '../../layouts/AdminLayout.astro'
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title="文章管理 | Miku Blog" description="后台文章管理" />
    <AdminRouteGuard />
  </head>
  <body>
    <AdminLayout activeKey="posts">
      <AdminSectionPlaceholder
        client:load
        module="posts"
        title="文章管理"
        description="这里将承载文章发布、草稿、分类与标签等管理能力。"
      />
    </AdminLayout>
  </body>
</html>
