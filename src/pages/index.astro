---
import BaseHead from '../components/BaseHead.astro';
import LiquidGlassCard from '../components/LiquidGlassCard.vue';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title="液态玻璃演示" description="液态玻璃模块演示页面" />
    <style>
      main {
        width: min(720px, calc(100% - 2rem));
        min-height: 100vh;
        margin: 0 auto;
        display: grid;
        place-items: center;
      }

      :global(.liquid-demo-card) {
        width: min(440px, 100%);
        min-height: 260px;
        padding: 2rem;
        border-radius: 32px;
        border: 1px solid rgba(255, 255, 255, 0.5);
        box-shadow: 0 20px 60px rgba(15, 18, 25, 0.2);
        background: rgba(255, 255, 255, 0.18);
        color: rgb(var(--black));
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        gap: 0.75rem;
      }

      :global(.liquid-demo-card h2) {
        margin: 0;
        font-size: 2rem;
      }

      :global(.liquid-demo-card p) {
        margin: 0;
        color: rgb(var(--gray-dark));
      }
    </style>
  </head>
  <body>
    <main>
    <LiquidGlassCard 
      client:load 
      options={{ borderRadius: 32, blur: 0.5, interactive: true }}
      class="liquid-demo-card"
    >
      <h2>液态玻璃模块</h2>
      <p>鼠标滑过试试看折射效果喵！</p>
    </LiquidGlassCard>
    </main>
  </body>
</html>
