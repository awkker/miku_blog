---
import FormattedDate from '../base/FormattedDate.astro'
import LiquidGlassCard from '../ui/LiquidGlassCard.vue'
import LikePanel from './LikePanel.vue'

interface Props {
  pubDate: Date
  updatedDate?: Date
  readingMinutes: number
  wordCount: number
  headingsCount: number
  tags: string[]
}

const {
  pubDate,
  updatedDate,
  readingMinutes,
  wordCount,
  headingsCount,
  tags = [],
}: Props = Astro.props
---

<div class="space-y-4">
  <LiquidGlassCard client:load maxWidth="100%" padding="16px 16px 18px" borderRadius={22}>
    <h3 class="text-xs font-bold tracking-[0.18em] text-slate-700">文章信息</h3>
    <dl class="mt-3 space-y-2 text-xs text-slate-600">
      <div class="flex items-center justify-between gap-3 rounded-lg border border-white/55 bg-white/45 px-3 py-2">
        <dt class="text-slate-500">发布时间</dt>
        <dd class="font-medium text-slate-700"><FormattedDate date={pubDate} /></dd>
      </div>
      {updatedDate && (
        <div class="flex items-center justify-between gap-3 rounded-lg border border-white/55 bg-white/45 px-3 py-2">
          <dt class="text-slate-500">最近更新</dt>
          <dd class="font-medium text-slate-700"><FormattedDate date={updatedDate} /></dd>
        </div>
      )}
      <div class="flex items-center justify-between gap-3 rounded-lg border border-white/55 bg-white/45 px-3 py-2">
        <dt class="text-slate-500">阅读时长</dt>
        <dd class="font-medium text-slate-700">{readingMinutes} 分钟</dd>
      </div>
      <div class="flex items-center justify-between gap-3 rounded-lg border border-white/55 bg-white/45 px-3 py-2">
        <dt class="text-slate-500">文章字数</dt>
        <dd class="font-medium text-slate-700">{wordCount.toLocaleString('zh-CN')} 字</dd>
      </div>
      <div class="flex items-center justify-between gap-3 rounded-lg border border-white/55 bg-white/45 px-3 py-2">
        <dt class="text-slate-500">目录节点</dt>
        <dd class="font-medium text-slate-700">{headingsCount} 节</dd>
      </div>
    </dl>

    <div class="mt-3 flex flex-wrap gap-1.5">
      {
        tags.map((tag) => (
          <span class="rounded-full border border-miku/30 bg-miku-soft px-2 py-0.5 text-[11px] text-miku">{tag}</span>
        ))
      }
    </div>
  </LiquidGlassCard>

  <div class="glass-layer rounded-2xl p-4">
    <h3 class="text-xs font-bold tracking-[0.18em] text-slate-700">互动</h3>
    <div class="mt-3 flex items-center gap-3">
      <LikePanel client:load initialCount={126} />
      <p class="text-xs leading-relaxed text-slate-500">
        喜欢这篇文章可以点个赞，也欢迎去留言板继续交流。
      </p>
    </div>
  </div>

  <div class="glass-layer rounded-2xl p-4">
    <h3 class="text-xs font-bold tracking-[0.18em] text-slate-700">站点入口</h3>
    <div class="mt-3 grid gap-2">
      <a href="/moments" class="rounded-lg border border-white/60 bg-white/56 px-3 py-2 text-xs text-slate-600 transition hover:border-miku/35 hover:text-miku">
        最新说说
      </a>
      <a href="/guestbook" class="rounded-lg border border-white/60 bg-white/56 px-3 py-2 text-xs text-slate-600 transition hover:border-miku/35 hover:text-miku">
        留言板
      </a>
      <a href="/about" class="rounded-lg border border-white/60 bg-white/56 px-3 py-2 text-xs text-slate-600 transition hover:border-miku/35 hover:text-miku">
        关于作者
      </a>
    </div>
  </div>
</div>
