---
import FormattedDate from '../base/FormattedDate.astro'
import LiquidGlassCard from '../ui/LiquidGlassCard.vue'

interface PostPreview {
  id: string
  title: string
  description: string
  pubDate: Date
}

interface Props {
  prevPost?: PostPreview | null
  nextPost?: PostPreview | null
  relatedPosts?: PostPreview[]
}

const { prevPost = null, nextPost = null, relatedPosts = [] }: Props = Astro.props

function toPostUrl(id: string): string {
  return `/blog/${id}/`
}
---

<section class="mx-auto mt-10 max-w-[1100px] space-y-5">
  <LiquidGlassCard client:load maxWidth="100%" padding="20px 20px 18px" borderRadius={24}>
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-start gap-3">
        <img
          src="/picture/author.jpg"
          alt="作者头像"
          class="h-14 w-14 rounded-2xl border border-white/70 object-cover"
          loading="lazy"
        />
        <div>
          <p class="text-xs tracking-[0.16em] text-miku">AUTHOR</p>
          <h2 class="text-xl font-bold text-slate-900">Nana Miku</h2>
          <p class="mt-1 text-sm leading-relaxed text-slate-600">
            写前端、写系统、写日常。希望每篇都能让你在下一次实现里更从容。
          </p>
        </div>
      </div>
      <a
        href="/about"
        class="inline-flex items-center justify-center rounded-xl border border-miku/35 bg-miku-soft px-3 py-2 text-xs font-semibold text-miku transition hover:border-miku/55"
      >
        查看完整介绍
      </a>
    </div>
  </LiquidGlassCard>

  <div class="grid gap-4 lg:grid-cols-2">
    <div class="glass-layer rounded-2xl p-4">
      <h3 class="text-xs font-bold tracking-[0.16em] text-slate-700">上一篇 / 下一篇</h3>
      <div class="mt-3 space-y-2.5">
        {nextPost ? (
          <a
            href={toPostUrl(nextPost.id)}
            class="block rounded-xl border border-white/65 bg-white/58 px-3 py-2.5 transition hover:border-miku/30"
          >
            <p class="text-[11px] text-miku">下一篇</p>
            <p class="mt-1 text-sm font-semibold text-slate-800">{nextPost.title}</p>
          </a>
        ) : (
          <div class="rounded-xl border border-white/65 bg-white/50 px-3 py-2.5 text-xs text-slate-500">下一篇暂未发布</div>
        )}

        {prevPost ? (
          <a
            href={toPostUrl(prevPost.id)}
            class="block rounded-xl border border-white/65 bg-white/58 px-3 py-2.5 transition hover:border-miku/30"
          >
            <p class="text-[11px] text-[#8b5cf6]">上一篇</p>
            <p class="mt-1 text-sm font-semibold text-slate-800">{prevPost.title}</p>
          </a>
        ) : (
          <div class="rounded-xl border border-white/65 bg-white/50 px-3 py-2.5 text-xs text-slate-500">已经是当前最早文章</div>
        )}
      </div>
    </div>

    <div class="glass-layer rounded-2xl p-4">
      <h3 class="text-xs font-bold tracking-[0.16em] text-slate-700">相关文章</h3>
      <div class="mt-3 space-y-2.5">
        {
          relatedPosts.length > 0 ? (
            relatedPosts.map((post) => (
              <a
                href={toPostUrl(post.id)}
                class="block rounded-xl border border-white/65 bg-white/58 px-3 py-2.5 transition hover:border-miku/30"
              >
                <p class="line-clamp-1 text-sm font-semibold text-slate-800">{post.title}</p>
                <p class="mt-1 line-clamp-2 text-xs text-slate-500">{post.description}</p>
                <p class="mt-1 text-[11px] text-slate-400">
                  <FormattedDate date={post.pubDate} />
                </p>
              </a>
            ))
          ) : (
            <div class="rounded-xl border border-white/65 bg-white/50 px-3 py-2.5 text-xs text-slate-500">暂无相关文章</div>
          )
        }
      </div>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    <a
      href="/moments"
      class="glass-layer block rounded-2xl p-4 transition hover:border-miku/40 hover:bg-white/36"
    >
      <p class="text-xs tracking-[0.16em] text-miku">最新说说</p>
      <h3 class="mt-1 text-base font-semibold text-slate-900">去看看最近在做什么</h3>
      <p class="mt-1 text-sm leading-relaxed text-slate-600">从文章回到日常开发记录，快速了解本站最新动态。</p>
    </a>

    <a
      href="/guestbook"
      class="glass-layer block rounded-2xl p-4 transition hover:border-[#c084fc]/45 hover:bg-white/36"
    >
      <p class="text-xs tracking-[0.16em] text-[#8b5cf6]">留言板</p>
      <h3 class="mt-1 text-base font-semibold text-slate-900">留下你的看法或问题</h3>
      <p class="mt-1 text-sm leading-relaxed text-slate-600">欢迎继续交流，文章观点、实现细节都可以在这里延伸讨论。</p>
    </a>
  </div>
</section>
